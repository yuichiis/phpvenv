#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once __DIR__ . '/../vendor/autoload.php';

use Rindow\PhpVenv\EnvironmentCreator;
use Rindow\PhpVenv\Filesystem;

error_reporting(E_ALL);

if (PHP_SAPI !== 'cli') {
    fwrite(STDERR, "CLI only.\n");
    exit(1);
}

// Basic usage check
if ($argc < 2) {
    fwrite(STDERR, "Usage: phpvenv <envname>\n");
    exit(1);
}

try {
    $envName = $argv[1];
    $creator = new EnvironmentCreator(new Filesystem());
    $creator->create($envName, getcwd());
    echo "\nDone.\n";
} catch (Exception $e) {
    fwrite(STDERR, "Error: " . $e->getMessage() . "\n");
    exit(1);
}
