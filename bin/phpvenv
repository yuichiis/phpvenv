#!/usr/bin/env php
<?php

declare(strict_types=1);

error_reporting(E_ALL);

if (PHP_SAPI !== 'cli') {
    fwrite(STDERR, "CLI only.\n");
    exit(1);
}

// Basic usage check
if ($argc < 2) {
    fwrite(STDERR, "Usage: phpvenv <envname>\n");
    exit(1);
}

$envName = $argv[1];

// Calculate environment paths
$cwd = getcwd();
$envDir = $cwd . DIRECTORY_SEPARATOR . $envName;

// Prevent overwriting existing directories
if (file_exists($envDir)) {
    fwrite(STDERR, "Directory already exists: {$envDir}\n");
    exit(1);
}

/**
 * Writes a file with Unix-style (LF) line endings and sets execution permissions.
 *
 * @param string $path
 * @param string $content
 */
function writeUnixFile(string $path, string $content): void
{
    $content = str_replace(
        ["\r\n", "\r"],
        "\n",
        $content
    );

    file_put_contents($path, $content);

    chmod($path, 0755);
}

/**
 * Writes a file with Windows-style (CRLF) line endings.
 *
 * @param string $path
 * @param string $content
 */
function writeWindowsFile(string $path, string $content): void
{
    $content = str_replace(
        ["\r\n", "\n"],
        "\r\n",
        $content
    );

    file_put_contents($path, $content);
}

// OS Detection and directory setup
$isWindows = DIRECTORY_SEPARATOR === '\\';

$binDir = $isWindows
    ? $envDir . DIRECTORY_SEPARATOR . 'Scripts'
    : $envDir . DIRECTORY_SEPARATOR . 'bin';

$cliDir = $envDir . DIRECTORY_SEPARATOR . 'cli';
$confDDir = $cliDir . DIRECTORY_SEPARATOR . 'conf.d';

// Create necessary directory structure
mkdir($envDir, 0777, true);
mkdir($binDir, 0777, true);
mkdir($cliDir, 0777, true);
mkdir($confDDir, 0777, true);

echo "Creating virtual environment: {$envDir}\n";

$phpBinary = PHP_BINARY;
$phpDir = dirname($phpBinary);

$loadedIni = php_ini_loaded_file();

// Copy the main php.ini to the virtual environment
if ($loadedIni && file_exists($loadedIni)) {
    copy($loadedIni, $cliDir . DIRECTORY_SEPARATOR . 'php.ini');
    echo "Copied php.ini\n";
}

//
// Copy additional ini files
//
$scanned = php_ini_scanned_files();

if ($scanned) {
    $files = array_map('trim', explode(',', $scanned));

    foreach ($files as $file) {
        if (!$file || !file_exists($file)) {
            continue;
        }

        copy(
            $file,
            $confDDir . DIRECTORY_SEPARATOR . basename($file)
        );
    }

    echo "Copied additional ini files\n";
}

//
// Windows activate.bat
//
$activateBat = <<<BAT
@echo off

set "_OLD_VIRTUAL_PROMPT=%PROMPT%"
set "_OLD_VIRTUAL_PATH=%PATH%"
set "_OLD_PHP_INI_SCAN_DIR=%PHP_INI_SCAN_DIR%"
set "_OLD_COMPOSER_HOME=%COMPOSER_HOME%"

set "VIRTUAL_ENV={$envDir}"

set "PATH=%VIRTUAL_ENV%\\composer\\vendor\\bin;{$binDir};%PATH%"

set "PHP_INI_SCAN_DIR={$confDDir}"

set "PROMPT=({$envName}) %PROMPT%"

set "COMPOSER_HOME=%VIRTUAL_ENV%\composer"

doskey deactivate={$binDir}\\deactivate.bat
BAT;


writeWindowsFile(
    $binDir . DIRECTORY_SEPARATOR . 'activate.bat',
    $activateBat
);

//
// Windows deactivate.bat
//
$deactivateBat = <<<BAT
@echo off

if defined _OLD_VIRTUAL_PROMPT (
    set "PROMPT=%_OLD_VIRTUAL_PROMPT%"
)

if defined _OLD_VIRTUAL_PATH (
    set "PATH=%_OLD_VIRTUAL_PATH%"
)

if defined _OLD_PHP_INI_SCAN_DIR (
    set "PHP_INI_SCAN_DIR=%_OLD_PHP_INI_SCAN_DIR%"
) else (
    set "PHP_INI_SCAN_DIR="
)

if defined _OLD_COMPOSER_HOME (
    set "COMPOSER_HOME=%_OLD_COMPOSER_HOME%"
) else (
    set "COMPOSER_HOME="
)

set _OLD_COMPOSER_HOME=
set _OLD_VIRTUAL_PROMPT=
set _OLD_VIRTUAL_PATH=
set _OLD_PHP_INI_SCAN_DIR=
set VIRTUAL_ENV=

BAT;

writeWindowsFile(
    $binDir . DIRECTORY_SEPARATOR . 'deactivate.bat',
    $deactivateBat
);

//
// PowerShell activate
//
$activatePs1 = <<<PS1
\$env:_OLD_VIRTUAL_PATH = \$env:PATH
\$env:_OLD_PHP_INI_SCAN_DIR = \$env:PHP_INI_SCAN_DIR
\$env:_OLD_COMPOSER_HOME = \$env:COMPOSER_HOME

if (Test-Path function:_OLD_VIRTUAL_PROMPT) {
    Remove-Item function:_OLD_VIRTUAL_PROMPT -ErrorAction SilentlyContinue
}

Copy-Item function:prompt function:_OLD_VIRTUAL_PROMPT

\$env:VIRTUAL_ENV = "{$envDir}"

\$env:PATH = "\$env:VIRTUAL_ENV\\composer\\vendor\\bin;{$binDir};" + \$env:PATH

\$env:PHP_INI_SCAN_DIR = "{$confDDir}"

\$env:COMPOSER_HOME = "\$env:VIRTUAL_ENV\composer"

function global:prompt {
    "({$envName}) " + (& _OLD_VIRTUAL_PROMPT)
}

function global:deactivate {

    \$env:PATH = \$env:_OLD_VIRTUAL_PATH

    if (\$env:_OLD_PHP_INI_SCAN_DIR) {
        \$env:PHP_INI_SCAN_DIR = \$env:_OLD_PHP_INI_SCAN_DIR
    }
    else {
        Remove-Item Env:PHP_INI_SCAN_DIR -ErrorAction SilentlyContinue
    }

    if (Test-Path function:_OLD_VIRTUAL_PROMPT) {

        Copy-Item function:_OLD_VIRTUAL_PROMPT function:prompt

        Remove-Item function:_OLD_VIRTUAL_PROMPT -ErrorAction SilentlyContinue
    }

    if (\$env:_OLD_COMPOSER_HOME) {
        \$env:COMPOSER_HOME = \$env:_OLD_COMPOSER_HOME
    }
    else {
        Remove-Item Env:COMPOSER_HOME -ErrorAction SilentlyContinue
    }


    Remove-Item function:deactivate -ErrorAction SilentlyContinue

    Remove-Item Env:_OLD_COMPOSER_HOME -ErrorAction SilentlyContinue
    Remove-Item Env:_OLD_VIRTUAL_PATH -ErrorAction SilentlyContinue
    Remove-Item Env:_OLD_PHP_INI_SCAN_DIR -ErrorAction SilentlyContinue
    Remove-Item Env:VIRTUAL_ENV -ErrorAction SilentlyContinue
}
PS1;


writeWindowsFile(
    $binDir . DIRECTORY_SEPARATOR . 'Activate.ps1',
    $activatePs1
);

//
// bash/zsh activate
//
$activateSh = <<<SH
#!/usr/bin/env bash

export _OLD_VIRTUAL_PATH="\$PATH"
export _OLD_PHP_INI_SCAN_DIR="\$PHP_INI_SCAN_DIR"
export _OLD_COMPOSER_HOME="\$COMPOSER_HOME"

if [ -n "\$PS1" ]; then
    export _OLD_VIRTUAL_PS1="\$PS1"
    export PS1="({$envName}) \$PS1"
fi

export VIRTUAL_ENV="{$envDir}"

export PATH="\$VIRTUAL_ENV/composer/vendor/bin:{$binDir}:\$PATH"

export PHP_INI_SCAN_DIR="{$confDDir}"

export COMPOSER_HOME="\$VIRTUAL_ENV/composer"

deactivate () {

    export PATH="\$_OLD_VIRTUAL_PATH"

    if [ -n "\$_OLD_PHP_INI_SCAN_DIR" ]; then
        export PHP_INI_SCAN_DIR="\$_OLD_PHP_INI_SCAN_DIR"
    else
        unset PHP_INI_SCAN_DIR
    fi

    if [ -n "\$_OLD_VIRTUAL_PS1" ]; then
        export PS1="\$_OLD_VIRTUAL_PS1"
    fi

    if [ -n "\$_OLD_COMPOSER_HOME" ]; then
        export COMPOSER_HOME="\$_OLD_COMPOSER_HOME"
    else
        unset COMPOSER_HOME
    fi

    unset _OLD_COMPOSER_HOME
    unset _OLD_VIRTUAL_PATH
    unset _OLD_PHP_INI_SCAN_DIR
    unset _OLD_VIRTUAL_PS1
    unset VIRTUAL_ENV

    unset -f deactivate
}
SH;

$activateShPath = $binDir . DIRECTORY_SEPARATOR . 'activate';

writeUnixFile($activateShPath, $activateSh);

if (!$isWindows) {
    chmod($activateShPath, 0755);
}

//
// launcher wrappers
//
if ($isWindows) {

    $phpBat = <<<BAT
@echo off

if "%~1"=="--ini" (
    shift
)
if "%~0"=="--ini" (
    "{$phpBinary}" ^
      --ini ^
      -c "{$cliDir}" ^
      %1 %2 %3 %4 %5 %6 %7 %8 %9
) else (
    "{$phpBinary}" ^
      -c "{$cliDir}" ^
      %*
)
BAT;

    writeWindowsFile(
        $binDir . DIRECTORY_SEPARATOR . 'php.bat',
        $phpBat
    );

} else {

$phpSh = <<<SH
#!/usr/bin/env bash

if [ "$1" = "--ini" ]; then
    shift

    exec "{$phpBinary}" \
      --ini \
      -c "{$cliDir}" \
      "\$@"
else
    exec "{$phpBinary}" \
      "\$@"
fi
SH;

    $phpShPath = $binDir . DIRECTORY_SEPARATOR . 'php';

    writeUnixFile($phpShPath, $phpSh);
    chmod($phpShPath, 0755);
}

// PowerShell wrapper for the php command
$phpPs1 = <<<PS1
if (\$args.Length -gt 0 -and \$args[0] -eq "--ini") {
    \$rest = @("--ini", "-c", "{$cliDir}")

    if (\$args.Length -gt 1) {
        \$rest += \$args[1..(\$args.Length - 1)]
    }

    & "{$phpBinary}" @rest
}
else {
    & "{$phpBinary}" @args
}
PS1;

writeWindowsFile(
    $binDir . DIRECTORY_SEPARATOR . 'php.ps1',
    $phpPs1
);

echo "Done.\n";

echo "\nActivate:\n";

if ($isWindows) {
    echo "  {$envDir}\\Scripts\\activate.bat\n";
    echo "  powershell -ExecutionPolicy Bypass -File {$envDir}\\Scripts\\Activate.ps1\n";
} else {
    echo "  source {$envDir}/bin/activate\n";
}
